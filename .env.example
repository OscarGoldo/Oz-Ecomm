# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret. Server-only. Used by the seed script and admin server actions.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────────────────────
# Base URL of the app (used for magic-link redirects and public store links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (optional) ─────────────────────────────────────────────────────────
# Resend API key for "new order" notifications to store owners.
# If unset, order emails are silently skipped (everything else works).
# https://resend.com → API Keys
RESEND_API_KEY=
# Verified sender. For testing you can use "Tiendify <onboarding@resend.dev>".
# In production use an address on a domain you verified in Resend.
EMAIL_FROM=Tiendify <onboarding@resend.dev>

# ── Cron (BCV rates) ─────────────────────────────────────────────────────────
# Secret that protects the daily BCV-rate cron route (/api/cron/bcv).
# Set the same value in Vercel; Vercel sends it as a Bearer token to the cron.
CRON_SECRET=
